#!/bin/sh
# .git/hooks/pre-commit

# Check for whitespace errors
git diff --cached --check


# Check for non-ASCII filenames (from the sample)
if git rev-parse --verify HEAD >/dev/null 2>&1
then
    against=HEAD
else
    against=$(git hash-object -t tree /dev/null)
fi

git diff --cached --name-only --diff-filter=A | grep -q '[^[:ascii:]]' && {
    echo "Error: Non-ASCII filenames detected"
    echo "   Please rename files to use only ASCII characters (a-z, A-Z, 0-9, -, _)."
    exit 1
}

# Check for files > 5MB in staged changes
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | while read file; do
    if [ -f "$file" ]; then
        SIZE=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null)
        if [ "$SIZE" -gt 5242880 ]; then
            echo "$file ($(($SIZE / 1024 / 1024))MB)"
        fi
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo "⚠️  WARNING: Large files detected (>5MB):"
    echo "$LARGE_FILES"
    echo ""
    echo "   Consider using Git LFS or storing in docs/_static/ with .gitignore"
    read -p "Continue anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

exit 0
