#!/bin/bash
# .git/hooks/post-release (manual trigger)

# Requires: npm install -g conventional-changelog-cli
PREV_TAG=$(git describe --tags --abbrev=0 HEAD~1 2>/dev/null || echo "")
CURRENT_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "v0.1.0")

if [ -n "$PREV_TAG" ]; then
    conventional-changelog -p angular -i CHANGELOG.md -s \
        --from "$PREV_TAG" --to "$CURRENT_TAG"
    echo "✅ CHANGELOG.md updated from $PREV_TAG to $CURRENT_TAG"
fi